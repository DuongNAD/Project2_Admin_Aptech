<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.web.HTMLEditor?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.elearning.admin.controllers.CourseDetailController"
            fitToWidth="true"
            styleClass="scroll-pane-clean">
    <content>
        <VBox spacing="20" styleClass="dashboard-root">

    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="courses-detail-header">
        <Button text="⬅ Quay lại" onAction="#onBackClicked" styleClass="courses-btn-back-modern"/>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <VBox spacing="2">
                <Label text="Tên khóa học *" styleClass="courses-editor-label"/>
                <TextField fx:id="titleField"
                           promptText="Nhập tên khóa học..."
                           styleClass="courses-title-input"/>
            </VBox>
            <VBox spacing="2">
                <Label text="Mô tả ngắn" styleClass="courses-editor-label"/>
                <TextField fx:id="subtitleField"
                           promptText="Mô tả ngắn về khóa học"
                           styleClass="courses-subtitle-input"/>
            </VBox>
        </VBox>
        <HBox spacing="8">
            <Button text="💾 Lưu bản nháp" onAction="#onSaveClicked" styleClass="courses-btn-secondary"/>
            <Button text="🚀 Xuất bản" onAction="#onPublishClicked" styleClass="courses-btn-primary"/>
        </HBox>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="courses-info-card" spacing="12" HBox.hgrow="ALWAYS">
            <Label text="Thông tin cơ bản" styleClass="courses-card-title"/>
            <HBox spacing="24">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Giá:" styleClass="courses-info-label"/>
                        <TextField fx:id="priceField"
                                   promptText="VD: 499.000 VNĐ"
                                   styleClass="courses-field"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Cấp độ:" styleClass="courses-info-label"/>
                        <ComboBox fx:id="levelField"
                                  promptText="Chọn level"
                                  prefWidth="140"
                                  styleClass="courses-combo"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Ngôn ngữ:" styleClass="courses-info-label"/>
                        <TextField fx:id="languageField"
                                   promptText="VD: Tiếng Việt"
                                   styleClass="courses-field"/>
                    </HBox>
                </VBox>
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Trạng thái:" styleClass="courses-info-label"/>
                        <ComboBox fx:id="statusField"
                                  promptText="Draft / Published"
                                  prefWidth="140"
                                  styleClass="courses-combo"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Giảng viên:" styleClass="courses-info-label"/>
                        <TextField fx:id="instructorField"
                                   promptText="Tên giảng viên"
                                   styleClass="courses-field"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Danh mục:" styleClass="courses-info-label"/>
                        <ComboBox fx:id="categoryField"
                                  promptText="Chọn danh mục"
                                  prefWidth="160"
                                  styleClass="courses-combo"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="courses-stats-card" spacing="12" prefWidth="260">
            <Label text="Thống kê" styleClass="courses-card-title"/>
            <HBox spacing="16">
                <VBox alignment="CENTER" styleClass="courses-stat-item">
                    <Label fx:id="statLessonsLabel" text="0" styleClass="courses-stat-number"/>
                    <Label text="Bài học" styleClass="courses-stat-label"/>
                </VBox>
                <VBox alignment="CENTER" styleClass="courses-stat-item">
                    <Label fx:id="statEnrollmentsLabel" text="0" styleClass="courses-stat-number"/>
                    <Label text="Học viên" styleClass="courses-stat-label"/>
                </VBox>
                <VBox alignment="CENTER" styleClass="courses-stat-item">
                    <Label fx:id="statRatingLabel" text="0.0" styleClass="courses-stat-number"/>
                    <Label text="Đánh giá" styleClass="courses-stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <TabPane fx:id="detailTabs" VBox.vgrow="ALWAYS" styleClass="courses-tabs-modern">
        <Tab text="📚 Phần &amp; Bài học" closable="false">
            <VBox spacing="12" styleClass="courses-tab-content">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Nội dung khóa học" styleClass="courses-tab-section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lessonsLabel" text="4 phần • 18 bài học" styleClass="courses-tab-count"/>
                </HBox>

                <HBox spacing="14" VBox.vgrow="ALWAYS">

                    <VBox spacing="10" prefWidth="260" styleClass="courses-builder-card" VBox.vgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Sections" styleClass="courses-builder-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="+ Thêm" onAction="#onAddSectionClicked" styleClass="courses-btn-add-mini"/>
                        </HBox>
                        <ListView fx:id="sectionsList" VBox.vgrow="ALWAYS" styleClass="courses-builder-list"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="✏️ Đổi tên" onAction="#onRenameSectionClicked" styleClass="courses-btn-secondary-mini"/>
                            <Button text="🗑️ Xóa" onAction="#onDeleteSectionClicked" styleClass="courses-btn-danger-mini"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="10" prefWidth="320" styleClass="courses-builder-card" VBox.vgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Bài giảng" styleClass="courses-builder-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="+ Thêm" onAction="#onAddLessonClicked" styleClass="courses-btn-add-mini"/>
                        </HBox>
                        <ListView fx:id="lessonsList" VBox.vgrow="ALWAYS" styleClass="courses-builder-list"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="🗑️ Xóa bài" onAction="#onDeleteLessonClicked" styleClass="courses-btn-danger-mini"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="selectedSectionLabel" text="Chưa chọn section" styleClass="courses-builder-hint"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="12" styleClass="courses-editor-panel" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Lesson Editor" styleClass="courses-builder-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="editorStateLabel" text="Chưa chọn bài giảng" styleClass="courses-builder-hint"/>
                        </HBox>

                        <VBox spacing="10" styleClass="courses-editor-body" VBox.vgrow="ALWAYS">
                            <VBox spacing="6">
                                <Label text="Tiêu đề bài giảng *" styleClass="courses-editor-label"/>
                                <TextField fx:id="lessonTitleField" promptText="VD: Giới thiệu Java" styleClass="courses-field"/>
                            </VBox>

                            <HBox spacing="12">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="Loại" styleClass="courses-editor-label"/>
                                    <ComboBox fx:id="lessonTypeField" promptText="Video / Article / Quiz" styleClass="courses-combo"/>
                                </VBox>
                                <VBox spacing="6">
                                    <Label text="Thời lượng (phút)" styleClass="courses-editor-label"/>
                                    <TextField fx:id="lessonDurationField" promptText="0" prefWidth="140" styleClass="courses-field"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <CheckBox fx:id="lessonPreviewCheck" text="Free preview" styleClass="courses-editor-check"/>
                            </HBox>

                            <VBox spacing="6" VBox.vgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="Nội dung bài giảng" styleClass="courses-editor-label"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="Chèn ảnh URL" onAction="#onInsertImageClicked" styleClass="courses-btn-secondary-mini"/>
                                </HBox>
                                <HTMLEditor fx:id="lessonHtmlEditor" prefHeight="260" VBox.vgrow="ALWAYS"/>
                            </VBox>
                        </VBox>

                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button text="Hủy" onAction="#onCancelLessonEditClicked" styleClass="courses-btn-secondary-mini"/>
                            <Button text="💾 Lưu bài giảng" onAction="#onSaveLessonClicked" styleClass="courses-btn-primary-mini"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="👥 Học viên" closable="false">
            <VBox spacing="12" styleClass="courses-tab-content">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Danh sách học viên đã đăng ký" styleClass="courses-tab-section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="tabEnrollmentsCountLabel" text="0 học viên" styleClass="courses-tab-count"/>
                </HBox>
                <TableView fx:id="enrollmentsTable" prefHeight="200" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="enrollStudentCol" text="Tên học viên" prefWidth="200"/>
                        <TableColumn fx:id="enrollDateCol" text="Ngày đăng ký" prefWidth="140"/>
                        <TableColumn fx:id="enrollProgressCol" text="Tiến độ" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="⭐ Đánh giá" closable="false">
            <VBox spacing="12" styleClass="courses-tab-content">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Đánh giá từ học viên" styleClass="courses-tab-section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="tabReviewsCountLabel" text="0 đánh giá • 0.0 ⭐" styleClass="courses-tab-count"/>
                </HBox>
                <TableView fx:id="reviewsTable" prefHeight="200" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="reviewUserCol" text="Học viên" prefWidth="160"/>
                        <TableColumn fx:id="reviewRatingCol" text="Điểm" prefWidth="80"/>
                        <TableColumn fx:id="reviewCommentCol" text="Bình luận" prefWidth="320"/>
                        <TableColumn fx:id="reviewDateCol" text="Ngày" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>
        </VBox>
    </content>
</ScrollPane>