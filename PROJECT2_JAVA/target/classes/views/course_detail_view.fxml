                <VBox alignment="CENTER" styleClass="courses-stat-item">
                    <Label text="4" styleClass="courses-stat-number"/>
                    <Label text="Học viên" styleClass="courses-stat-label"/>
                </VBox>
                <VBox alignment="CENTER" styleClass="courses-stat-item">
                    <Label text="4.5" styleClass="courses-stat-number"/>
                    <Label text="Đánh giá" styleClass="courses-stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <!-- Tabs -->
    <TabPane fx:id="detailTabs" VBox.vgrow="ALWAYS" styleClass="courses-tabs-modern">
        <!-- Tab 1: Sections & Lessons -->
