<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.web.HTMLEditor?>
<?import javafx.scene.layout.*?>

<!--
  Course Detail - Modern Dark Theme (scrollable)
-->
<ScrollPane xmlns:fx="http://javafx.com/fxml"
