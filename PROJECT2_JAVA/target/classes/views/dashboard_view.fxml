<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.elearning.admin.controllers.DashboardController"
      spacing="16"
      styleClass="dashboard-root">

    <HBox spacing="16">
        <children>
            <VBox spacing="8" styleClass="dash-card dash-card-income">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Tổng doanh thu" styleClass="dash-card-title"/>
                        <Label text="+12.5%" styleClass="dash-badge-positive"/>
                    </children>
                </HBox>
                <Label fx:id="revenueLabel" text="348,261 $" styleClass="dash-card-value"/>
                <Label text="So với tháng trước" styleClass="dash-card-sub"/>
            </VBox>

            <VBox spacing="8" styleClass="dash-card dash-card-courses">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Số khóa học" styleClass="dash-card-title"/>
                        <Label text="+8" styleClass="dash-badge-neutral"/>
                    </children>
                </HBox>
                <Label fx:id="coursesCountLabel" text="128" styleClass="dash-card-value"/>
                <Label text="Khóa học đang hoạt động" styleClass="dash-card-sub"/>
            </VBox>

            <VBox spacing="8" styleClass="dash-card dash-card-students">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Học viên đang học" styleClass="dash-card-title"/>
                        <Label text="+320" styleClass="dash-badge-positive"/>
                    </children>
                </HBox>
                <Label fx:id="studentsCountLabel" text="7,415" styleClass="dash-card-value"/>
                <Label text="Trong 30 ngày gần đây" styleClass="dash-card-sub"/>
            </VBox>
        </children>
    </HBox>

    <VBox spacing="8">
        <children>
            <Label text="Phân tích theo quý" styleClass="dash-section-title"/>
            <HBox spacing="16">
                <children>
                    <LineChart fx:id="revenueChart"
                               prefHeight="220"
                               legendVisible="false"
                               HBox.hgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis fx:id="xAxis" label="Quý"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="yAxis" label="Doanh thu ($)"/>
                        </yAxis>
                    </LineChart>

                    <BarChart fx:id="enrollmentChart"
                              prefHeight="220"
                              legendVisible="false"
                              HBox.hgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis fx:id="enrollXAxis" label="Quý"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="enrollYAxis" label="Học viên mới"/>
                        </yAxis>
                    </BarChart>
                </children>
            </HBox>
        </children>
    </VBox>

    <VBox spacing="8">
        <children>
            <Label text="Khóa học đăng ký gần đây" styleClass="dash-section-title"/>
            <TableView fx:id="ordersTable"
                       prefHeight="200"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="enrollmentDateCol" text="Ngày đăng ký" prefWidth="140"/>
                    <TableColumn fx:id="studentCol" text="Học viên" prefWidth="160"/>
                    <TableColumn fx:id="courseCol" text="Khóa học" prefWidth="220"/>
                    <TableColumn fx:id="progressCol" text="Tiến độ" prefWidth="100"/>
                    <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="110"/>
                </columns>
            </TableView>
        </children>
    </VBox>

</VBox>