            <!-- Revenue Chart -->
            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="orders-chart-container">
                <Label text="Doanh thu 30 ngày" styleClass="orders-chart-title"/>
                <LineChart fx:id="revenueChart" prefHeight="180" legendVisible="false">
                    <xAxis>
                        <CategoryAxis fx:id="revXAxis"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis fx:id="revYAxis"/>
                    </yAxis>
