                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <VBox spacing="4">
                            <Label text="Trạng thái" styleClass="orders-filter-label"/>
                            <ComboBox fx:id="statusFilter" promptText="Tất cả" prefWidth="140" styleClass="orders-combo"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Từ ngày" styleClass="orders-filter-label"/>
                            <DatePicker fx:id="startDatePicker" prefWidth="140" styleClass="orders-datepicker"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Đến ngày" styleClass="orders-filter-label"/>
                            <DatePicker fx:id="endDatePicker" prefWidth="140" styleClass="orders-datepicker"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Xuất báo cáo" styleClass="orders-btn-export"/>
                    </HBox>
                </VBox>

                <!-- Orders Table -->
