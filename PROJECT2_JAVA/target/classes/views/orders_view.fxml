                    </xAxis>
                    <yAxis>
                        <NumberAxis fx:id="ordYAxis"/>
                    </yAxis>
                </BarChart>
            </VBox>
        </HBox>

        <!-- Main content: Orders Table + Detail -->
        <HBox spacing="20" prefHeight="500">
            <!-- Left: Orders List -->
            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <!-- Filter bar -->
                <VBox spacing="12" styleClass="orders-filter-card">
