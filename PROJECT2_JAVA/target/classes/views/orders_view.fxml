                            <TableColumn fx:id="amountCol" text="T�.ng tiền" prefWidth="110"/>
                            <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="110"/>
                            <TableColumn fx:id="createdCol" text="Ngày tạo" prefWidth="120"/>
