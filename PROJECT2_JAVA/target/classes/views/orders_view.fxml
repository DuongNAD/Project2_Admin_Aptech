            </VBox>

            <!-- Orders Chart -->
            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="orders-chart-container">
                <Label text="S�' �'ơn hàng" styleClass="orders-chart-title"/>
                <BarChart fx:id="ordersChart" prefHeight="180" legendVisible="false">
                    <xAxis>
